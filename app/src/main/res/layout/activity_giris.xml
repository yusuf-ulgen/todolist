<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".Giris">

    <!-- Bütün formu saracak ve ortalayacak container -->
    <LinearLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Mail Satırı -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/mailtext_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kullanıcı Maili:"
                android:textSize="16sp"/>

            <EditText
                android:id="@+id/mail_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:hint="Mailinizi giriniz"
                android:inputType="textEmailAddress"/>
        </LinearLayout>

        <!-- Şifre Satırı -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/sifretext_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Şifre:"
                android:textSize="16sp"/>

            <EditText
                android:id="@+id/sifre_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:hint="Şifrenizi giriniz"
                android:inputType="textPassword"/>
        </LinearLayout>

        <!-- Giriş ve Kaydol Butonları -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/girisyap_id"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Giriş Yap"
                android:backgroundTint="#025421"
                android:textColor="@android:color/white"/>

            <Button
                android:id="@+id/kaydet_id"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Kaydol"
                android:backgroundTint="#F60707"
                android:textColor="@android:color/white"/>
        </LinearLayout>

        <!-- Google ile Giriş Yap Butonu -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/signInButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="0dp"
            android:text="Google ile Giriş Yap"
            app:icon="@drawable/google"
            app:iconTint="@null"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/gray"
            android:backgroundTint="@android:color/white"
            android:textColor="@android:color/black"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>