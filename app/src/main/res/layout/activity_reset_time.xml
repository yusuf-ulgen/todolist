<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/creamBackground"
    android:padding="16dp">

    <!-- Başlık: Resetleme Saati Seçimi -->
    <TextView
        android:id="@+id/resetTimePickerTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resetleme Saatini Seçin"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/creamPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- TimePicker: Resetleme Saati Seçimi -->
    <TimePicker
        android:id="@+id/timePicker"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/resetTimePickerTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Kaydet Butonu -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/saveResetTimeButton"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Kaydet"
        app:backgroundTint="@color/creamPrimary"
        android:textColor="@color/creamOnPrimary"
        app:layout_constraintTop_toBottomOf="@id/timePicker"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Kaydedilen Reset Saati Gösterimi -->
    <TextView
        android:id="@+id/savedResetTimeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kaydedilen Reset Saati:"
        android:textSize="16sp"
        android:textColor="@color/creamOnBackground"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/saveResetTimeButton"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/savedResetTimeValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--:--"
        android:textSize="16sp"
        android:textColor="@color/creamOnBackground"
        app:layout_constraintBaseline_toBaselineOf="@id/savedResetTimeLabel"
        app:layout_constraintStart_toEndOf="@id/savedResetTimeLabel"
        android:layout_marginStart="8dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
