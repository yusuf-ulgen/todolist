<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/creamBackground"
    android:padding="16dp">

    <!-- Tema Seçimi Butonu -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/themeButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="40dp"
        android:text="Tema"
        android:textSize="18sp"
        app:backgroundTint="@color/creamPrimary"
        android:textColor="@color/creamOnPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Resetleme Zamanı Butonu -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/resetTimeButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        android:text="Resetleme Zamanı"
        android:textSize="18sp"
        app:backgroundTint="@color/creamPrimaryVariant"
        android:textColor="@color/creamOnPrimary"
        app:layout_constraintTop_toBottomOf="@id/themeButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- İstatistiklerim Butonu -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/statisticsButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        android:text="İstatistiklerim"
        android:textSize="18sp"
        app:backgroundTint="@color/creamPrimary"
        android:textColor="@color/creamOnPrimary"
        app:layout_constraintTop_toBottomOf="@id/resetTimeButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Şifre Butonu -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/changePasswordButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        android:text="Şifre"
        android:textSize="18sp"
        app:backgroundTint="@color/creamPrimaryVariant"
        android:textColor="@color/creamOnPrimary"
        app:layout_constraintTop_toBottomOf="@id/statisticsButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
