<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="32dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="?attr/feedbackBackground"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:id="@+id/feedbackHeaderTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Geri Bildirim"
            android:textColor="?attr/feedbackHeaderText"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- Content Area -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/feedbackTitleLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxStrokeColor="?attr/feedbackHeaderText"
            app:hintTextColor="?attr/feedbackInputHint"
            android:hint="Problem Başlığı"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/feedbackTitleEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/feedbackInputText" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/feedbackMessageLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:boxStrokeColor="?attr/feedbackHeaderText"
            app:hintTextColor="?attr/feedbackInputHint"
            android:hint="Problemi Girin..."
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/feedbackMessageEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:minLines="5"
                android:textColor="?attr/feedbackInputText" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Footer (Buttons) -->
        <LinearLayout
            android:id="@+id/feedbackFooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/feedbackCancelButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="İptal"
                android:textAllCaps="false"
                android:textColor="?attr/feedbackHeaderText"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/feedbackNextButton"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="İleri"
                android:textAllCaps="false"
                android:backgroundTint="?attr/feedbackHeaderBackground"
                android:textColor="?attr/feedbackHeaderText"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
