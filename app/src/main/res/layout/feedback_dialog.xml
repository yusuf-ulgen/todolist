<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:padding="16dp">

    <!-- Problem Başlığı -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/feedbackTitleLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="?attr/colorPrimaryVariant"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/feedbackTitleEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Problem Başlığı"
            android:inputType="textCapSentences"
            android:textColor="?attr/colorOnBackground"
            android:textColorHint="?attr/colorOnBackground" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Problem Mesajı -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/feedbackMessageLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="@color/creamPrimaryVariant"
        app:layout_constraintTop_toBottomOf="@id/feedbackTitleLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/feedbackMessageEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Problemi Girin..."
            android:inputType="textCapSentences|textMultiLine"
            android:lines="4"
            android:gravity="start"
            android:textColor="@color/creamOnBackground"
            android:textColorHint="@color/creamOnBackground" />
    </com.google.android.material.textfield.TextInputLayout>

</androidx.constraintlayout.widget.ConstraintLayout>