<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- Toolbar + TabLayout -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            app:backgroundTint="?attr/colorPrimary"
            app:subtitleTextColor="?attr/colorOnPrimary"
            app:subtitleTextAppearance="@style/SubtitleLarge"
            app:subtitleCentered="true"/>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabIndicatorColor="?attr/colorOnPrimary"
            app:tabTextColor="?attr/tabUnselectedTextColor"
            app:tabSelectedTextColor="?attr/tabSelectedTextColor">

            <com.google.android.material.tabs.TabItem
                android:text="Günlük"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content" />

            <com.google.android.material.tabs.TabItem
                android:text="Haftalık"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </com.google.android.material.tabs.TabLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- İçerikler -->
    <include
        android:id="@+id/includeDaily"
        layout="@layout/content_main"/>

    <include
        android:id="@+id/includeWeekly"
        layout="@layout/content_weekly"
        android:visibility="gone"/>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        app:srcCompat="@android:drawable/ic_input_add"
        app:backgroundTint="?attr/colorPrimaryVariant"
        android:tint="?attr/colorOnPrimary"/>

    <!-- İstatistik metni (toolbar altında) -->
    <TextView
        android:id="@+id/toolbarStatText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="12dp"
        android:text="Bugünün görevleri 0/0"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnPrimary"
        app:layout_anchor="@id/toolbar"
        app:layout_anchorGravity="bottom"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>