<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/creamBackground"
    android:padding="8dp">

    <!-- Görev Numarası -->
    <TextView
        android:id="@+id/taskNumber"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="1"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/creamPrimaryVariant"
        app:layout_constraintWidth_percent="0.10"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Checkbox -->
    <CheckBox
        android:id="@+id/taskCheckBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:tint="@color/creamPrimary"
        app:layout_constraintWidth_percent="0.10"
        app:layout_constraintStart_toEndOf="@id/taskNumber"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Görev Metni ve Pin Ikonu -->
    <FrameLayout
        android:id="@+id/taskFrame"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="4dp"
        app:layout_constraintStart_toEndOf="@id/taskCheckBox"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintWidth_percent="0.58">

        <EditText
            android:id="@+id/taskEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Görev girin..."
            android:textColor="@color/creamOnBackground"
            android:textColorHint="@color/creamOnBackground"
            android:textSize="16sp"
            android:backgroundTint="@color/creamPrimaryVariant"
            android:padding="8dp"
            android:scrollHorizontally="true"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:focusable="true"
            android:focusableInTouchMode="true" />

        <ImageView
            android:id="@+id/pinIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="4dp"
            android:contentDescription="Pin Icon"
            android:src="@drawable/ic"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Saat -->
    <TextView
        android:id="@+id/timeTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Saat"
        android:textColor="@color/creamPrimaryVariant"
        android:textSize="14sp"
        android:gravity="end"
        android:padding="8dp"
        app:layout_constraintStart_toEndOf="@id/taskFrame"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintWidth_percent="0.25" />

</androidx.constraintlayout.widget.ConstraintLayout>