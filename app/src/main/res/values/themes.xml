<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Uygulamanın ana teması, DayNight özellikli -->
    <style name="Theme.ToDoList" parent="Theme.MaterialComponents.DayNight.NoActionBar.Bridge">
        <!-- Primary / Secondary -->
        <item name="colorPrimary">@color/creamPrimary</item>
        <item name="colorPrimaryVariant">@color/creamPrimaryVariant</item>
        <item name="colorOnPrimary">@color/creamOnPrimary</item>

        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/creamOnPrimary</item>

        <!-- Arka plan & yüzeyler -->
        <item name="android:colorBackground">@color/creamBackground</item>
        <item name="colorSurface">@color/creamBackground</item>
        <item name="colorOnBackground">@color/creamOnBackground</item>
        <item name="colorOnSurface">@color/creamOnBackground</item>

        <!-- Sistem bar -->
        <item name="android:statusBarColor">@color/creamPrimaryVariant</item>
        <item name="android:navigationBarColor">@color/creamBackground</item>

        <!-- Material Variantları -->
        <item name="colorPrimaryVariant">@color/creamPrimaryVariant</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/creamPrimary</item>
        <item name="colorOnSecondary">@color/creamOnPrimary</item>

        <!-- Metin renkleri -->
        <item name="android:textColorPrimary">@color/task_text_default</item>
        <item name="android:textColorSecondary">@color/gray</item>

        <!-- Accent / ripple vb -->
        <item name="colorAccent">@color/colorAccent</item>

        <!-- TabLayout için text renkleri -->
        <item name="tabUnselectedTextColor">@color/light_tab_unselected</item>
        <item name="tabSelectedTextColor">@color/light_tab_selected</item>
        <item name="tabIndicatorColor">@color/colorAccent</item>

        <!-- TimePicker Teması -->
        <item name="android:timePickerStyle">@style/Widget.App.TimePicker</item>

        <item name="taskTextDefault">@color/task_text_default</item>
        <item name="taskTextChecked">@color/task_text_checked</item>
        <item name="taskSupplementaryColor">@color/creamOnPrimary</item>

        <!-- Button colors for light theme -->
        <item name="controlButtonColor">@color/button_text_light</item>

        <!-- Pin ikonu -->
        <item name="pinIcon">@drawable/pin_light</item>
        <item name="gray">@color/gray</item>

        <!-- Snapshot Styling -->
        <item name="snackbarButtonStyle">@style/Widget.App.Snackbar.Button</item>
        
        <!-- Feedback Dialog Attributes -->
        <item name="feedbackBackground">@color/white</item>
        <item name="feedbackHeaderBackground">@color/white</item>
        <item name="feedbackHeaderText">@color/black</item>
        <item name="feedbackInputBackground">#F5F5F5</item>
        <item name="feedbackInputText">@color/black</item>
        <item name="feedbackInputHint">#999999</item>
        <item name="snackbarActionColor">#795548</item>
    </style>

    <style name="CustomAlertDialog" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="Widget.App.TimePicker" parent="android:Widget.Material.Light.TimePicker">
        <item name="android:headerBackground">@color/creamPrimary</item>
        <item name="android:numbersTextColor">@color/brown_accent</item>
        <item name="android:numbersSelectorColor">#CC5D4037</item> <!-- 80% alpha brown_accent (#5D4037) -->
        <item name="android:numbersBackgroundColor">@color/creamPrimaryVariant</item>
        <item name="android:amPmTextColor">@color/brown_accent</item>
    </style>

    <!-- Snackbar Style Override -->
    <style name="Widget.App.Snackbar.Button" parent="Widget.MaterialComponents.Button.TextButton.Snackbar">
        <item name="android:textColor">?attr/controlButtonColor</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SubtitleLarge" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:gravity">center</item>
        <item name="android:textSize">18sp</item>
    </style>

</resources>