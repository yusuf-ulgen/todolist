<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Uygulamanın ana teması, DayNight özellikli -->
    <style name="Theme.ToDoList" parent="Theme.MaterialComponents.DayNight.NoActionBar.Bridge">
        <!-- Primary / Secondary -->
        <item name="colorPrimary">@color/creamPrimary</item>
        <item name="colorPrimaryVariant">@color/creamPrimaryVariant</item>
        <item name="colorOnPrimary">@color/creamOnPrimary</item>

        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/creamOnPrimary</item>

        <!-- Arka plan & yüzeyler -->
        <item name="android:colorBackground">@color/creamBackground</item>
        <item name="colorSurface">@color/creamBackground</item>
        <item name="colorOnBackground">@color/creamOnBackground</item>
        <item name="colorOnSurface">@color/creamOnBackground</item>

        <!-- Sistem bar -->
        <item name="android:statusBarColor">@color/creamPrimaryVariant</item>
        <item name="android:navigationBarColor">@color/creamBackground</item>

        <!-- Metin renkleri -->
        <item name="android:textColorPrimary">@color/task_text_default</item>
        <item name="android:textColorSecondary">@color/gray</item>

        <!-- Accent / ripple vb -->
        <item name="colorAccent">@color/colorAccent</item>

        <!-- TabLayout için text renkleri (app:tabTextColors="?attr/tabTextColor") -->
        <item name="tabUnselectedTextColor">@color/light_tab_unselected</item>
        <item name="tabSelectedTextColor">@color/light_tab_selected</item>
        <item name="tabIndicatorColor">@color/colorAccent</item>

        <item name="taskTextDefault">@color/task_text_default</item>
        <item name="taskTextChecked">@color/task_text_checked</item>

        <!-- Pin ikonu -->
        <item name="pinIcon">@drawable/pin_light</item>
    </style>

    <style name="SubtitleLarge" parent="TextAppearance.MaterialComponents.Subtitle1">
        <!-- Bu iki özellik TextAppearance içinde pek kullanılmaz, ama sen eklemiştin -->
        <item name="android:gravity">center</item>
        <item name="android:textSize">18sp</item>
    </style>

</resources>