<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Uygulamanın ana teması, light ve dark arasında otomatik geçiş yapar -->
    <style name="Theme.ToDoList" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Toolbar, FAB vb. ana renkler -->
        <item name="colorPrimary">@color/creamPrimary</item>
        <item name="colorPrimaryVariant">@color/creamPrimaryVariant</item>
        <item name="colorOnPrimary">@color/creamOnPrimary</item>

        <!-- Secondary renkler (Snackbar, switch thumb vb) -->
        <item name="colorSecondary">@color/creamPrimary</item>
        <item name="colorSecondaryVariant">@color/creamPrimaryVariant</item>
        <item name="colorOnSecondary">@color/creamOnPrimary</item>

        <!-- Uygulama arka planı ve üzerine yazı -->
        <item name="android:windowBackground">@color/creamBackground</item>
        <item name="colorSurface">@color/creamBackground</item>
        <item name="colorOnSurface">@color/creamOnBackground</item>

        <!-- Sistem bar renkleri -->
        <item name="android:statusBarColor">@color/creamPrimaryVariant</item>
        <item name="android:navigationBarColor">@color/creamBackground</item>

        <!-- Genel varsayılan metin rengi -->
        <item name="android:textColorPrimary">@color/creamOnBackground</item>
    </style>

    <style name="SubtitleLarge" parent="TextAppearance.MaterialComponents.Subtitle1">
        <!-- Genişliğini tüm ekrana yayalım ki ortalanabilsin -->
        <item name="android:layout_width">match_parent</item>
        <!-- Metni ortalamak için -->
        <item name="android:gravity">center</item>
        <!-- İstediğin büyüklükte yap -->
        <item name="android:textSize">18sp</item>
    </style>

</resources>
